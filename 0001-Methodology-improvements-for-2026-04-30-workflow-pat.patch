   workflow_dispatch:
 
 concurrency:
@@ -30,6 +33,51 @@ jobs:
         id: date
         run: echo "date=$(date +'%Y-%m-%d')" >> $GITHUB_OUTPUT
 
+      - name: Detect stale pipelines
+        id: stale
+        run: |
+          # Flag any per-source directory whose newest dated file is more
+          # than 36h old (relative to today). Catches silent outages like
+          # the hourly-twitter and hourly-rss runners that went dark for
+          # 2+ days through April 27-29 with no alert.
+          TODAY="${{ steps.date.outputs.date }}"
+          TODAY_EPOCH=$(date -d "$TODAY" +%s)
+          STALE_REPORT="/tmp/stale-pipelines.txt"
+          : > "$STALE_REPORT"
+
+          for dir in twitter rss bluesky community arxiv twitter-deepseek models; do
+            d="research/$dir"
+            [ -d "$d" ] || continue
+            # Newest YYYY-MM-DD-prefixed file in dir
+            NEWEST=$(ls "$d" 2>/dev/null \
+              | grep -E '^[0-9]{4}-[0-9]{2}-[0-9]{2}' \
+              | sort -r | head -n 1)
+            if [ -z "$NEWEST" ]; then
+              echo "STALE: research/$dir — no dated files at all" >> "$STALE_REPORT"
+              continue
+            fi
+            NEWEST_DATE=$(echo "$NEWEST" | grep -oE '^[0-9]{4}-[0-9]{2}-[0-9]{2}')
+            NEWEST_EPOCH=$(date -d "$NEWEST_DATE" +%s)
+            AGE_HOURS=$(( (TODAY_EPOCH - NEWEST_EPOCH) / 3600 ))
+            if [ "$AGE_HOURS" -gt 36 ]; then
+              echo "STALE: research/$dir — newest=$NEWEST (~${AGE_HOURS}h old)" >> "$STALE_REPORT"
+            fi
+          done
+
+          if [ -s "$STALE_REPORT" ]; then
+            echo "=== Stale pipelines detected ==="
+            cat "$STALE_REPORT"
+            STALE_BODY=$(cat "$STALE_REPORT")
+            {
+              echo 'report<<EOF'
+              echo "$STALE_BODY"
+              echo 'EOF'
+            } >> $GITHUB_OUTPUT
+          else
+            echo "All pipelines fresh."
+            echo 'report=' >> $GITHUB_OUTPUT
+          fi
+
       - name: Setup Node.js
         uses: actions/setup-node@v4
         with:
