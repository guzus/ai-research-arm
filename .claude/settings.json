{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0"
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "denyRead": [
        "~/",
        "/root",
        "/proc",
        "/sys",
        "/run",
        "/etc/ssh",
        "/etc/ssl/private"
      ],
      "allowRead": [
        ".",
        ".git/config"
      ]
    },
    "credentials": {
      "files": [
        {
          "path": "~/.aws",
          "mode": "deny"
        },
        {
          "path": "~/.config/gh",
          "mode": "deny"
        },
        {
          "path": "~/.docker",
          "mode": "deny"
        },
        {
          "path": "~/.ssh",
          "mode": "deny"
        },
        {
          "path": "~/.claude",
          "mode": "deny"
        },
        {
          "path": "~/.claude.json",
          "mode": "deny"
        }
      ],
      "envVars": [
        {
          "name": "ANTHROPIC_API_KEY",
          "mode": "deny"
        },
        {
          "name": "ANTHROPIC_AUTH_TOKEN",
          "mode": "deny"
        },
        {
          "name": "CLAUDE_CODE_OAUTH_TOKEN",
          "mode": "deny"
        },
        {
          "name": "FIREWORKS_API_KEY",
          "mode": "deny"
        },
        {
          "name": "ZAI_API_KEY",
          "mode": "deny"
        },
        {
          "name": "GITHUB_TOKEN",
          "mode": "deny"
        },
        {
          "name": "GH_TOKEN",
          "mode": "deny"
        }
      ]
    }
  },
  "permissions": {
    "deny": [
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.docker/**)",
      "Read(~/.ssh/**)",
      "Read(~/.claude/**)",
      "Read(~/.claude.json)",
      "Read(./.git/config)",
      "Read(//root/**)",
      "Read(//proc/**)",
      "Read(//sys/**)",
      "Read(//run/**)",
      "Read(//etc/ssh/**)",
      "Read(//etc/ssl/private/**)"
    ]
  }
}
