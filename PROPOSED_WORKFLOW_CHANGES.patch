+          UA="Mozilla/5.0 (compatible; AIResearchBot/1.0)"
+
+          # Helper: fetch a feed and validate that the response actually parses as RSS/Atom.
+          # If the upstream is dead, we log the failure (visible in Actions logs) and write
+          # an empty-but-valid stub so the downstream Claude step still has a file to read.
+          fetch_feed() {
+            local name="$1"
+            local url="$2"
+            local out="/tmp/rss/${name}.xml"
+            local code
+            code=$(curl -sL --max-time 25 -H "User-Agent: $UA" -w "%{http_code}" -o "$out" "$url" || echo "000")
+            local size
+            size=$(wc -c < "$out" 2>/dev/null || echo 0)
+            if [ "$code" != "200" ] || [ "$size" -lt 200 ] || ! grep -qE "<(item|entry)" "$out"; then
+              echo "::warning::feed $name http=$code size=$size url=$url — falling back to empty stub"
+              echo '<?xml version="1.0"?><rss version="2.0"><channel></channel></rss>' > "$out"
+            else
+              echo "OK $name http=$code size=$size $(grep -cE "<item|<entry" "$out") items"
+            fi
+          }
