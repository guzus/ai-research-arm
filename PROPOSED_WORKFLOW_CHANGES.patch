+          # Bluesky public AppView. As of 2026-05-05 the `public.api.bsky.app` host
+          # returns 403 to all unauthenticated requests; `api.bsky.app` works.
+          BSKY_API="https://api.bsky.app"
+          UA="Mozilla/5.0 (compatible; AIResearchBot/1.0)"
+
+          # Helper: fetch a Bluesky search and validate the response is JSON containing
+          # a `posts` array. On failure write a valid empty stub so downstream parsing
+          # doesn't blow up — but log it so the failure is visible in the Actions log.
+          fetch_bsky() {
+            local name="$1"
+            local query="$2"
+            local out="/tmp/bluesky/${name}.json"
+            local code
+            code=$(curl -sL --max-time 25 -H "User-Agent: $UA" -H "Accept: application/json" \
+              -w "%{http_code}" -o "$out" \
+              "${BSKY_API}/xrpc/app.bsky.feed.searchPosts?q=${query}&limit=50&sort=latest" \
+              || echo "000")
+            if [ "$code" != "200" ] || ! head -c 1 "$out" | grep -q '{'; then
+              echo "::warning::bluesky fetch $name http=$code — falling back to empty stub"
+              echo '{"posts":[]}' > "$out"
+            else
+              local posts
+              posts=$(grep -o '"uri":"' "$out" | wc -l)
+              echo "OK $name http=$code posts=$posts"
+            fi
+            sleep 1
+          }
+
+          fetch_bsky ai_announcements "AI%20announcement"
+          fetch_bsky llm_releases     "LLM%20release"
+          fetch_bsky model_discussions "GPT%20Claude%20Gemini"
+          fetch_bsky ml_papers         "machine%20learning%20paper"
+          fetch_bsky agents_tools      "agent%20framework%20tool-use"
+
+          # Posts from named AI accounts. Bluesky search supports `from:handle` syntax.
+          fetch_bsky karpathy   "from%3Akarpathy.bsky.social"
+          fetch_bsky simonw     "from%3Asimonwillison.net"
+          fetch_bsky emollick   "from%3Aemollick.bsky.social"
+          fetch_bsky natolambert "from%3Anatolambert.bsky.social"
+
+          echo "Bluesky data fetched"
+          ls -la /tmp/bluesky/

