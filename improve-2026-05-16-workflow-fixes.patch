+
+          # fetch <url> <out>
+          # Saves response to <out>; if HTTP failed or body isn't a feed
+          # (no <rss|<rdf|<feed), replaces it with an empty RSS stub so the
+          # downstream parser ignores it instead of treating an HTML 403 page
+          # as content. Silent rot was the root cause of the 2026-04-27 →
+          # 2026-05-16 RSS outage.
+          fetch() {
+            local url="$1" out="$2"
+            local code
+            code=$(curl -sL --max-time 20 -A "$UA" -o "$out" -w "%{http_code}" "$url" || echo "000")
+            if [[ "$code" != 2* ]] || ! grep -qiE "<rss|<rdf|<feed" "$out"; then
+              echo "[!] $url HTTP=$code wrong-shape — stubbing"
+              echo "<rss></rss>" > "$out"
+            fi
