diff --git a/.github/workflows/daily-arxiv.yml b/.github/workflows/daily-arxiv.yml
index a6279d7b..747b28f9 100644
--- a/.github/workflows/daily-arxiv.yml
+++ b/.github/workflows/daily-arxiv.yml
@@ -86,6 +86,18 @@ jobs:
             - Application papers with no novel methods
             - Papers from unknown authors with few citations

+            AUTHOR FIDELITY (required):
+            For every paper you list, capture the REAL author names from the
+            arXiv metadata (the MCP tool's `authors` field, or the "Authors"
+            line on the abstract page). Use the first 1-3 surnames followed by
+            "et al." when the list is long (e.g. "Chung, Wang, Chen, et al.")
+            and add an affiliation in parentheses when known. NEVER emit a bare
+            "**Authors**: et al." with no preceding name — if you cannot
+            resolve any name, fetch the paper's abstract page before writing
+            it; if it still cannot be resolved, drop that paper rather than
+            ship an empty author field. (Recent runs intermittently lost the
+            top papers' author names; this guard closes that gap.)
+
             FORMAT:

             # arXiv AI Research - ${{ steps.date.outputs.date }}
