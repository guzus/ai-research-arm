+          fetch_feed "https://importai.substack.com/feed"                             /tmp/rss/import_ai.xml
+          fetch_feed "https://www.interconnects.ai/feed"                              /tmp/rss/interconnects.xml
+          fetch_feed "https://www.oneusefulthing.org/feed"                            /tmp/rss/oneusefulthing.xml
+          fetch_feed "https://www.latent.space/feed"                                  /tmp/rss/latent_space.xml
+          fetch_feed "https://www.lesswrong.com/feed.xml"                             /tmp/rss/lesswrong.xml
+
+          # --- Research ---
+          fetch_feed "https://export.arxiv.org/rss/cs.AI"                             /tmp/rss/arxiv_ai.xml
+          fetch_feed "https://export.arxiv.org/rss/cs.LG"                             /tmp/rss/arxiv_lg.xml
+          fetch_feed "https://export.arxiv.org/rss/cs.CL"                             /tmp/rss/arxiv_cl.xml
+
+          # --- Tech press ---
