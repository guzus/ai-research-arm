+          echo "Bluesky data fetched. Per-file post counts:"
+          for f in /tmp/bluesky/*.json; do
+            N=$(jq '.posts | length' "$f" 2>/dev/null || echo 0)
+            printf "  %-40s posts=%s\n" "$(basename "$f")" "$N"
+          done

