+          bsky_search "GPT%20Claude%20Gemini"      /tmp/bluesky/model_discussions.json 30; sleep 1
+          bsky_search "machine%20learning%20paper" /tmp/bluesky/ml_papers.json        30; sleep 1
+
+          # --- Curated researcher feeds (handles verified HTTP 200 2026-05-14).
+          # `from:` search syntax has been unreliable/rate-limited for years;
