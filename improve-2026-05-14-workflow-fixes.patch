+          bsky_author "karpathy.bsky.social"       /tmp/bluesky/karpathy.json       20; sleep 1
+          bsky_author "simonw.bsky.social"         /tmp/bluesky/simonw.json         20; sleep 1
+          bsky_author "emollick.bsky.social"       /tmp/bluesky/emollick.json       20; sleep 1
+          bsky_author "natolambert.bsky.social"    /tmp/bluesky/natolambert.json    20; sleep 1
+          bsky_author "goodside.bsky.social"       /tmp/bluesky/goodside.json       20; sleep 1
+          bsky_author "jasonwei.bsky.social"       /tmp/bluesky/jasonwei.json       20; sleep 1
+          bsky_author "jackclark.bsky.social"      /tmp/bluesky/jackclark.json      20; sleep 1
+          bsky_author "demishassabis.bsky.social"  /tmp/bluesky/demishassabis.json  20; sleep 1
+          bsky_author "arvindn.bsky.social"        /tmp/bluesky/arvindn.json        20; sleep 1
+          bsky_author "gwern.bsky.social"          /tmp/bluesky/gwern.json          20
