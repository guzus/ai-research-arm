+          UA="Mozilla/5.0 (compatible; AIResearchBot/1.0)"
+
+          # `public.api.bsky.app` started returning HTTP 403 in early May 2026
+          # and silently zeroed out this feed for ~14 days. The unprefixed
+          # `api.bsky.app` host serves the same xrpc endpoints over plain
+          # HTTPS and returns 200 — verified 2026-05-14.
+          BSKY_API="https://api.bsky.app"
+
+          # Keyword-search fetch. Normalizes to {"posts":[...]} or an empty
+          # stub if the response isn't JSON.
+          bsky_search() {
+            local q="$1" out="$2" n="${3:-30}"
+            curl -sL -o "$out" --max-time 20 \
+              -H "User-Agent: $UA" -H "Accept: application/json" \
+              "${BSKY_API}/xrpc/app.bsky.feed.searchPosts?q=${q}&limit=${n}&sort=latest"
+            if ! jq -e '.posts' "$out" >/dev/null 2>&1; then
+              echo "[!] bsky search '${q}' returned non-JSON — empty stub"
+              echo '{"posts":[]}' > "$out"
+            fi
+          }
+
+          # Author-feed fetch for a known handle. Normalizes the
+          # {"feed":[{"post":...}]} response to the same {"posts":[...]}
+          # shape as search so the downstream prompt stays uniform.
+          bsky_author() {
+            local handle="$1" out="$2" n="${3:-20}"
+            curl -sL -o "$out" --max-time 20 \
+              -H "User-Agent: $UA" -H "Accept: application/json" \
+              "${BSKY_API}/xrpc/app.bsky.feed.getAuthorFeed?actor=${handle}&limit=${n}&filter=posts_no_replies"
+            if jq -e '.feed' "$out" >/dev/null 2>&1; then
+              jq '{posts: [.feed[].post]}' "$out" > "${out}.tmp" && mv "${out}.tmp" "$out"
+            else
+              echo "[!] bsky author-feed '${handle}' returned non-JSON — empty stub"
+              echo '{"posts":[]}' > "$out"
+            fi
+          }
+
