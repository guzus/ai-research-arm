+          UA="Mozilla/5.0 (compatible; AIResearchBot/1.0)"
+
+          # Status-aware + content-type-sniffing fetcher. The pre-patch code
+          # used `curl -sL ... > out`, which silently wrote 4xx/5xx HTML bodies
+          # and HTML-from-broken-proxies to disk. Three feeds had been broken
+          # this way for 17+ days (Meta AI 404, googleaiblog.blogspot.com
+          # frozen since 2025-10, openrss.org/anthropic serving HTML instead
+          # of RSS) without any visibility in workflow logs.
+          fetch_feed() {
+            local url="$1" out="$2" code
+            code=$(curl -sL --max-time 30 -o "$out" -w "%{http_code}" \
+              -H "User-Agent: $UA" \
+              -H "Accept: application/rss+xml, application/atom+xml, application/xml;q=0.9, */*;q=0.5" \
+              "$url" || echo "000")
+            if [ "${code:0:1}" != "2" ]; then
+              echo "[!] $(basename "$out"): HTTP $code from $url — empty stub"
+              echo "<rss><channel></channel></rss>" > "$out"
+              return
+            fi
+            if ! grep -qiE "<rss|<feed|<rdf" "$out"; then
+              echo "[!] $(basename "$out"): non-feed body (HTML?) from $url — empty stub"
+              echo "<rss><channel></channel></rss>" > "$out"
+              return
+            fi
+            echo "[+] $(basename "$out"): HTTP $code, $(wc -c < "$out") bytes"
+          }
+
+          # --- Official lab blogs ---
+          fetch_feed "https://openai.com/news/rss.xml"                                /tmp/rss/openai.xml
+          # Anthropic has no native RSS; openrss.org proxy currently serves HTML.
+          # Kept so the slot exists (with empty-stub fallback) for the day a
+          # working feed appears.
+          fetch_feed "https://openrss.org/www.anthropic.com/news"                     /tmp/rss/anthropic.xml
+          # research.google/blog/rss/ is the live canonical Google research blog.
+          # Two legacy URLs are frozen and were silently producing empty data:
+          #   googleaiblog.blogspot.com/atom.xml — last <updated> 2025-10-07
+          #   blog.research.google/atom.xml       — same content, also frozen
+          fetch_feed "https://research.google/blog/rss/"                              /tmp/rss/google_research.xml
+          fetch_feed "https://deepmind.google/blog/rss.xml"                           /tmp/rss/deepmind.xml
+          # ai.meta.com/blog/rss/ returns HTTP 404. engineering.fb.com ships
+          # an ML-applications feed that surfaces the same Meta AI announcements.
+          fetch_feed "https://engineering.fb.com/category/ml-applications/feed/"      /tmp/rss/meta_ai.xml
+          fetch_feed "https://huggingface.co/blog/feed.xml"                           /tmp/rss/huggingface.xml
+          fetch_feed "https://cohere.com/blog/rss.xml"                                /tmp/rss/cohere.xml
+
