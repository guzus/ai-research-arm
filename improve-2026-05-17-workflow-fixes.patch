-            > /tmp/bluesky/ai_announcements.json
-
+          # `public.api.bsky.app` started returning HTTP 403 from this runner
+          # in early May 2026 (BunnyCDN IP/UA gating) and silently zeroed out
+          # this feed for ~17 days. The unprefixed `api.bsky.app` host serves
+          # the same xrpc endpoints and returns 200 with a browser UA.
+          BSKY_API="https://api.bsky.app"
+          UA="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36"
+
+          # bsky_search <query> <out>
+          # Falls back to {"posts":[]} stub if the response isn't JSON.
+          bsky_search() {
+            local q="$1" out="$2"
+            curl -sL --max-time 20 -A "$UA" -H "Accept: application/json" \
+              "${BSKY_API}/xrpc/app.bsky.feed.searchPosts?q=${q}&limit=30&sort=latest" \
+              -o "$out"
+            if ! head -c1 "$out" | grep -q '{'; then
+              echo "[!] bsky search '${q}' returned non-JSON — empty stub"
+              echo '{"posts":[]}' > "$out"
+            fi
+          }
+
+          bsky_search "AI%20announcement"          /tmp/bluesky/ai_announcements.json
           sleep 1
