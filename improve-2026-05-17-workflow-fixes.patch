           sleep 1
-
-          curl -s "https://public.api.bsky.app/xrpc/app.bsky.feed.searchPosts?q=machine%20learning%20paper&limit=30&sort=latest" \
-            > /tmp/bluesky/ml_papers.json
-
+          bsky_search "machine%20learning%20paper" /tmp/bluesky/ml_papers.json
           sleep 1
-
-          # Get posts from known AI researchers/companies by searching their handles
-          curl -s "https://public.api.bsky.app/xrpc/app.bsky.feed.searchPosts?q=from%3Akarpathy.bsky.social&limit=20&sort=latest" \
-            > /tmp/bluesky/karpathy.json 2>/dev/null || echo '{"posts":[]}' > /tmp/bluesky/karpathy.json
+          bsky_search "from%3Akarpathy.bsky.social" /tmp/bluesky/karpathy.json

           echo "Bluesky data fetched successfully"

