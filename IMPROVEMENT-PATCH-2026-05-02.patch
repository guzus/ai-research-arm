+          # Bluesky public XRPC endpoint. NOTE: public.api.bsky.app started
+          # returning HTTP 403 with an HTML error page for unauthenticated
+          # XRPC calls around 2026-04-27 (CDN/anti-bot block on datacenter
+          # IP ranges — confirmed in the 04-28..05-01 bluesky digests, which
+          # all logged "HTTP 403 Forbidden for all source files"). The
+          # alternate host api.bsky.app — same XRPC surface, different
+          # CDN — still returns valid JSON.
+          BSKY_HOST="https://api.bsky.app"
+          UA="Mozilla/5.0 (compatible; AIResearchBot/1.0; +https://github.com/${{ github.repository }})"
+
+          # Topic-based searchPosts. {"posts":[...]} envelope.
+          fetch_search() {
+            local out="$1" query="$2"
+            curl -sSL --retry 3 --retry-delay 2 \
+              -H "User-Agent: $UA" \
+              "$BSKY_HOST/xrpc/app.bsky.feed.searchPosts?q=${query}&limit=30&sort=latest" \
+              -o "$out" || echo '{"posts":[]}' > "$out"
+            # Normalize HTML error pages (response starts with "<") to a
+            # valid empty-results JSON envelope so the Claude step doesn't
+            # crash on HTML-as-JSON.
+            if [ "$(head -c 1 "$out" 2>/dev/null)" = "<" ]; then
+              echo "WARN: $out returned HTML — normalizing to {\"posts\":[]}"
+              echo '{"posts":[]}' > "$out"
+            fi
+          }
+
+          # Per-author timeline. {"feed":[{"post":{...}}, ...]} envelope.
+          fetch_author() {
+            local out="$1" actor="$2"
+            curl -sSL --retry 3 --retry-delay 2 \
+              -H "User-Agent: $UA" \
+              "$BSKY_HOST/xrpc/app.bsky.feed.getAuthorFeed?actor=${actor}&limit=20" \
+              -o "$out" || echo '{"feed":[]}' > "$out"
+            if [ "$(head -c 1 "$out" 2>/dev/null)" = "<" ]; then
+              echo "WARN: $out returned HTML — normalizing to {\"feed\":[]}"
+              echo '{"feed":[]}' > "$out"
+            fi
+          }
+
+          fetch_search /tmp/bluesky/ai_announcements.json   "AI%20announcement"
           sleep 1
