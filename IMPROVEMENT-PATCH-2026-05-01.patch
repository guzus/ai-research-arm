+      - name: Pipeline freshness audit
+        id: freshness
+        run: |
+          # Deterministic check of whether each upstream pipeline produced
+          # a file recently. The 2026-04-30 digest silently noted Twitter
+          # was 2 days stale and RSS 4 days stale; surfacing this here
+          # gives the next improve cycle a hard signal it can act on.
+          echo "## Pipeline Freshness Audit" | tee -a $GITHUB_STEP_SUMMARY
+          echo "" | tee -a $GITHUB_STEP_SUMMARY
+          echo "| Pipeline | Latest file | Age (h) | Status |" | tee -a $GITHUB_STEP_SUMMARY
+          echo "|----------|-------------|---------|--------|" | tee -a $GITHUB_STEP_SUMMARY
+
+          : > /tmp/pipeline-freshness.txt
+          NOW_TS=$(date +%s)
+          STALE_PIPES=""
+
+          # subdir : warn-after-hours threshold (cron cadence x 6 + slack)
+          while IFS=':' read -r dir threshold; do
+            [ -z "$dir" ] && continue
+            latest=""
+            mtime=0
+            if [ -d "research/$dir" ]; then
+              # newest regular file in the directory (any extension)
+              latest=$(find "research/$dir" -maxdepth 1 -type f -printf '%T@ %p\n' 2>/dev/null \
+                       | sort -nr | head -1 | awk '{print $2}')
+              if [ -n "$latest" ]; then
+                mtime=$(stat -c %Y "$latest" 2>/dev/null || stat -f %m "$latest" 2>/dev/null || echo 0)
+              fi
+            fi
+            if [ -z "$latest" ]; then
+              status="NO FILES"
+              age_h="-"
+              STALE_PIPES="$STALE_PIPES $dir"
+            else
+              age_s=$(( NOW_TS - mtime ))
+              age_h=$(( age_s / 3600 ))
+              if [ "$age_h" -gt "$threshold" ]; then
+                status="STALE (>${threshold}h)"
+                STALE_PIPES="$STALE_PIPES $dir"
+              else
+                status="OK"
+              fi
+            fi
+            echo "| $dir | ${latest##*/} | ${age_h} | ${status} |" | tee -a $GITHUB_STEP_SUMMARY
+            echo "$dir|$latest|$age_h|$status" >> /tmp/pipeline-freshness.txt
+          done <<EOF
+          twitter:6
+          twitter-deepseek:9
+          rss:3
+          community:6
+          arxiv:30
+          bluesky:30
+          digest:30
+          models:30
+          front-page:30
+          summaries:6
+          audio:30
+          EOF
+
+          STALE_PIPES=$(echo "$STALE_PIPES" | xargs)
+          echo "" | tee -a $GITHUB_STEP_SUMMARY
+          if [ -n "$STALE_PIPES" ]; then
+            echo "Stale pipelines detected: \`$STALE_PIPES\`" | tee -a $GITHUB_STEP_SUMMARY
+          else
+            echo "All pipelines fresh." | tee -a $GITHUB_STEP_SUMMARY
+          fi
+          echo "stale_pipelines=$STALE_PIPES" >> $GITHUB_OUTPUT
+
