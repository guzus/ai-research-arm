+          # Bluesky API host: `api.bsky.app` (no `public.` prefix).
+          # `public.api.bsky.app` started returning HTTP 403 around early May 2026,
+          # which silently zeroed out this feed for ~2 weeks. `api.bsky.app`
+          # serves the same unauthenticated xrpc endpoints and returns 200.
+          BSKY_API="https://api.bsky.app"
+          UA="Mozilla/5.0 (compatible; AIResearchBot/1.0)"
+
+          # Helper: fetch + validate JSON shape so HTML/error pages don't poison
+          # downstream parsing. On failure, write `{"posts":[]}` so the LLM step
+          # always sees a well-formed file.
+          bsky_search() {
+            local query="$1"
+            local out="$2"
+            local n="${3:-30}"
+            curl -sL -o "$out" \
+              -H "User-Agent: $UA" \
+              -H "Accept: application/json" \
+              "${BSKY_API}/xrpc/app.bsky.feed.searchPosts?q=${query}&limit=${n}&sort=latest"
+            if ! jq -e '.posts' "$out" >/dev/null 2>&1; then
+              echo "[!] bsky search '${query}' returned non-JSON — replacing with empty posts"
+              echo '{"posts":[]}' > "$out"
+            fi
+          }
+
+          bsky_search "AI%20announcement"            /tmp/bluesky/ai_announcements.json 30; sleep 1
+          bsky_search "LLM%20release"                /tmp/bluesky/llm_releases.json     30; sleep 1
+          bsky_search "GPT%20Claude%20Gemini"        /tmp/bluesky/model_discussions.json 30; sleep 1
+          bsky_search "machine%20learning%20paper"   /tmp/bluesky/ml_papers.json        30; sleep 1
+
+          # Pull recent posts from known AI researchers via the author-feed
+          # endpoint (more reliable than `from:` search syntax, which Bluesky
+          # search has historically rate-limited or silently dropped).
+          bsky_author() {
+            local handle="$1"
+            local out="$2"
+            local n="${3:-20}"
+            curl -sL -o "$out" \
+              -H "User-Agent: $UA" \
+              -H "Accept: application/json" \
+              "${BSKY_API}/xrpc/app.bsky.feed.getAuthorFeed?actor=${handle}&limit=${n}&filter=posts_no_replies"
+            # getAuthorFeed returns `{"feed":[...]}`; normalize to `{"posts":[...]}`
+            # by extracting the `.post` field so the LLM prompt's schema stays uniform.
+            if jq -e '.feed' "$out" >/dev/null 2>&1; then
+              jq '{posts: [.feed[].post]}' "$out" > "${out}.tmp" && mv "${out}.tmp" "$out"
+            else
+              echo "[!] bsky author-feed '${handle}' returned non-JSON — replacing"
+              echo '{"posts":[]}' > "$out"
+            fi
+          }
+
+          bsky_author "karpathy.bsky.social"   /tmp/bluesky/karpathy.json    20
           sleep 1
