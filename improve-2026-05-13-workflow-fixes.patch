+          UA="Mozilla/5.0 (compatible; AIResearchBot/1.0)"
+
+          # Fetch with HTTP-status validation. curl -sL silently writes 4xx/5xx
+          # response bodies to disk, so before this guard, broken feeds like
+          # the old googleaiblog.blogspot.com (301), ai.meta.com/blog/rss/ (404)
+          # and venturebeat (308 to a non-feed URL after the slash change) were
+          # poisoning /tmp/rss/*.xml with HTML and silently shrinking coverage.
+          fetch_feed() {
+            local url="$1"
+            local out="$2"
+            local code
+            code=$(curl -sL --max-time 30 -o "$out" -w "%{http_code}" \
+              -H "User-Agent: $UA" \
+              -H "Accept: application/rss+xml, application/atom+xml, application/xml, text/xml;q=0.9, */*;q=0.5" \
+              "$url" || echo "000")
+            # Accept 2xx; on anything else replace with empty <rss/> so the
+            # downstream LLM parse doesn't crash on HTML/error bodies.
+            if [ "${code:0:1}" != "2" ]; then
+              echo "[!] $(basename "$out"): HTTP $code from $url — writing empty stub"
+              echo "<rss></rss>" > "$out"
+              return
+            fi
+            # Sanity check: must contain a feed-like root tag, not HTML.
+            if ! grep -qiE "<rss|<feed|<rdf" "$out"; then
+              echo "[!] $(basename "$out"): non-feed body from $url — writing empty stub"
+              echo "<rss></rss>" > "$out"
+              return
+            fi
+            echo "[+] $(basename "$out"): HTTP $code, $(wc -c < "$out") bytes"
+          }
+
+          # --- Official lab blogs ---
+          fetch_feed "https://openai.com/news/rss.xml" /tmp/rss/openai.xml
+          # Anthropic has no native feed; openrss.org rebroadcasts /news.
+          fetch_feed "https://openrss.org/www.anthropic.com/news" /tmp/rss/anthropic.xml
+          # blog.research.google replaced googleaiblog.blogspot.com (which now
+          # 301s to a generic feedburner). Atom feed is the canonical Google
+          # AI/Research source as of 2026.
+          fetch_feed "http://blog.research.google/atom.xml" /tmp/rss/google_ai.xml
+          # DeepMind ships its own RSS at deepmind.google (separate from
+          # research.google). Both are kept so we see both org's posts.
+          fetch_feed "https://deepmind.google/blog/rss.xml" /tmp/rss/deepmind.xml
+          fetch_feed "https://research.google/blog/rss/" /tmp/rss/google_research.xml
+          # ai.meta.com/blog/rss/ now 404s. engineering.fb.com still ships RSS
+          # under the ML category and surfaces the same announcements.
+          fetch_feed "https://engineering.fb.com/category/ml-applications/feed/" /tmp/rss/meta_ai.xml
+          fetch_feed "https://huggingface.co/blog/feed.xml" /tmp/rss/huggingface.xml
+          fetch_feed "https://cohere.com/blog/rss.xml" /tmp/rss/cohere.xml
+
+          # --- Research ---
