+          # public.api.bsky.app started returning HTTP 403 (BunnyCDN
+          # anti-bot block on this datacenter IP) around 2026-04-27 —
+          # confirmed by repeated "_No posts processed: upstream Bluesky
+          # fetch returned HTTP 403 Forbidden_" entries in
+          # research/bluesky/2026-04-28..2026-05-03. The alternate host
+          # api.bsky.app exposes the same XRPC surface on a different CDN
+          # and continues to return valid JSON.
+          BSKY_HOST="https://api.bsky.app"
+          UA="Mozilla/5.0 (compatible; AIResearchBot/1.0; +https://github.com/${{ github.repository }})"
+
+          # Topic-based searchPosts. {"posts":[...]} envelope.
+          fetch_search() {
+            local out="$1" query="$2"
+            curl -sSL --retry 3 --retry-delay 2 \
+              -H "User-Agent: $UA" \
+              "$BSKY_HOST/xrpc/app.bsky.feed.searchPosts?q=${query}&limit=30&sort=latest" \
+              -o "$out" || echo '{"posts":[]}' > "$out"
+            # Normalize HTML error pages (response starts with "<") to a
+            # valid empty-results JSON envelope so the Claude step doesn't
+            # crash on HTML-as-JSON.
+            if [ "$(head -c 1 "$out" 2>/dev/null)" = "<" ]; then
+              echo "WARN: $out returned HTML — normalizing to {\"posts\":[]}"
+              echo '{"posts":[]}' > "$out"
+            fi
+          }
+
+          # Per-author timeline. {"feed":[{"post":{...}}, ...]} envelope.
+          # Bluesky search has no `from:` operator — getAuthorFeed is the
+          # correct primitive for "posts by user X".
+          fetch_author() {
+            local out="$1" actor="$2"
+            curl -sSL --retry 3 --retry-delay 2 \
