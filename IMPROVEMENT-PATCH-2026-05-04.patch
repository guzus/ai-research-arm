+              "$BSKY_HOST/xrpc/app.bsky.feed.getAuthorFeed?actor=${actor}&limit=20" \
+              -o "$out" || echo '{"feed":[]}' > "$out"
+            if [ "$(head -c 1 "$out" 2>/dev/null)" = "<" ]; then
+              echo "WARN: $out returned HTML — normalizing to {\"feed\":[]}"
+              echo '{"feed":[]}' > "$out"
+            fi
+          }
