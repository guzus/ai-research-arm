--- a/.github/workflows/daily-improve.yml
+++ b/.github/workflows/daily-improve.yml
@@ -32,11 +32,17 @@ jobs:
           echo "branch=improve/$(date +'%Y-%m-%d')" >> $GITHUB_OUTPUT

       - name: Analyze and Improve Methodology
+        env:
+          # gh CLI uses GH_TOKEN for `gh pr create`. Without this the
+          # `gh pr create` step at the end of the prompt fails silently —
+          # which is why every prior improve/<date> branch (2026-04-28 to
+          # 2026-05-02) has a commit but no PR.
+          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
         uses: anthropics/claude-code-action@v1
         with:
           claude_code_oauth_token: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}
           claude_args: |
-            --model opus --allowedTools "Glob,Read,Write,Edit,Bash(git:*),WebSearch"
+            --model opus --allowedTools "Glob,Read,Write,Edit,Bash(git:*),Bash(gh:*),Bash(curl:*),Bash(ls:*),Bash(wc:*),Bash(head:*),Bash(tail:*),Bash(grep:*),WebSearch"
           prompt: |
             You are an AI research methodology optimizer. Analyze yesterday's output quality and propose improvements.

@@ -135,9 +141,27 @@ jobs:
       - name: Push changes if on branch
         env:
           GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
         run: |
           CURRENT_BRANCH=$(git branch --show-current)
           if [ "$CURRENT_BRANCH" != "main" ]; then
             git remote set-url origin https://x-access-token:${GITHUB_TOKEN}@github.com/${{ github.repository }}.git
             git push -u origin $CURRENT_BRANCH || echo "Already pushed or no changes"
+
+            # Backstop PR creation: if Claude could not create the PR
+            # itself (e.g. allowedTools regression, gh-cli missing) but
+            # left commits on an improve/<date> branch, open a PR here so
+            # the work doesn't sit invisible. Idempotent — gh exits 0 if
+            # the PR already exists for this branch.
+            if command -v gh >/dev/null 2>&1; then
+              EXISTING_PR=$(gh pr list --head "$CURRENT_BRANCH" --json number --jq '.[0].number' 2>/dev/null || echo "")
+              if [ -z "$EXISTING_PR" ]; then
+                gh pr create \
+                  --title "🔄 Daily Methodology Improvement - $(echo $CURRENT_BRANCH | sed 's|improve/||')" \
+                  --body "Auto-generated improvement PR from daily-improve workflow. Branch contains methodology changes proposed by analyzing yesterday's research output. Review the diff for details." \
+                  --base main --head "$CURRENT_BRANCH" || echo "gh pr create failed (non-fatal)"
+              else
+                echo "PR #$EXISTING_PR already exists for $CURRENT_BRANCH — skipping create."
+              fi
+            fi
           fi
