+          UA="Mozilla/5.0 (compatible; AIResearchBot/1.0)"
+
+          # fetch_feed <url> <outfile> — record HTTP status, fall back to empty <rss/>
+          # if the feed is non-200 or empty. Without this, dead feeds went undetected
+          # for ~15 days (last successful RSS run was 2026-04-27).
+          fetch_feed() {
+            local url="$1"
+            local outfile="$2"
+            local http_code
+            http_code=$(curl -sSL -o "$outfile" -w "%{http_code}" \
+              -H "User-Agent: $UA" --max-time 20 "$url" || echo "000")
+            local size
+            size=$(wc -c < "$outfile" 2>/dev/null || echo 0)
+            if [ "$http_code" != "200" ] || [ "$size" -lt 100 ]; then
+              echo "WARN: $url returned HTTP $http_code, size=$size bytes — substituting empty feed" >&2
+              echo "<rss><channel></channel></rss>" > "$outfile"
+            else
+              echo "OK: $url -> $outfile ($size bytes)"
+            fi
+          }
+
+          # --- Official Company Blogs ---
+          fetch_feed "https://openai.com/news/rss.xml"                /tmp/rss/openai.xml
+          fetch_feed "https://openrss.org/www.anthropic.com/news"     /tmp/rss/anthropic.xml
+          fetch_feed "https://research.google/blog/rss/"              /tmp/rss/google_ai.xml
+          # NOTE: ai.meta.com/blog/rss/ has been 404 since at least May 2026; using
+          # openrss bridge against the blog index instead.
+          fetch_feed "https://openrss.org/ai.meta.com/blog"           /tmp/rss/meta_ai.xml
+          fetch_feed "https://huggingface.co/blog/feed.xml"           /tmp/rss/huggingface.xml
+          fetch_feed "https://openrss.org/mistral.ai/news"            /tmp/rss/mistral.xml
+          fetch_feed "https://cohere.com/blog/rss.xml"                /tmp/rss/cohere.xml
+
+          # --- Research ---
+          fetch_feed "https://export.arxiv.org/rss/cs.AI"             /tmp/rss/arxiv_ai.xml
+          fetch_feed "https://export.arxiv.org/rss/cs.LG"             /tmp/rss/arxiv_lg.xml
+
+          # --- Tech News ---
+          fetch_feed "https://techcrunch.com/category/artificial-intelligence/feed/" /tmp/rss/techcrunch_ai.xml
+          fetch_feed "https://www.theverge.com/rss/ai-artificial-intelligence/index.xml" /tmp/rss/verge_ai.xml
+          fetch_feed "https://venturebeat.com/category/ai/feed/"      /tmp/rss/venturebeat_ai.xml
+          fetch_feed "https://arstechnica.com/ai/feed/"               /tmp/rss/arstechnica_ai.xml
+          fetch_feed "https://www.technologyreview.com/topic/artificial-intelligence/feed/" /tmp/rss/mit_techreview_ai.xml
+
+          # --- Practitioner / Researcher Commentary (new in 2026-05-12 improvement) ---
+          # High-signal individual voices that historically break or first-analyze
+          # frontier-model news ahead of mainstream press.
+          fetch_feed "https://simonwillison.net/atom/everything/"     /tmp/rss/simon_willison.xml
+          fetch_feed "https://www.latent.space/feed"                  /tmp/rss/latent_space.xml
+          fetch_feed "https://jack-clark.net/feed/"                   /tmp/rss/import_ai.xml
+
+          echo "RSS feeds fetched. Summary:"
           ls -la /tmp/rss/

