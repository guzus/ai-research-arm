+          # Bluesky AppView search endpoint.
+          # NOTE: public.api.bsky.app/xrpc/app.bsky.feed.searchPosts began returning
+          # 403 Forbidden in 2026 (Bluesky restricted access on that subdomain).
+          # api.bsky.app responds without auth for the same endpoint, so we use that.
+          BSKY_BASE="https://api.bsky.app/xrpc/app.bsky.feed.searchPosts"
+          UA="Mozilla/5.0 (compatible; AIResearchBot/1.0)"
+
+          fetch_bsky() {
+            local query="$1"
+            local outfile="$2"
+            local http_code
+            http_code=$(curl -sS -o "$outfile" -w "%{http_code}" \
+              -H "User-Agent: $UA" \
+              "${BSKY_BASE}?q=${query}&limit=30&sort=latest" || echo "000")
+            if [ "$http_code" != "200" ]; then
+              echo "WARN: Bluesky search for '$query' returned HTTP $http_code — substituting empty result" >&2
+              echo '{"posts":[]}' > "$outfile"
+            fi
+          }
+
+          fetch_bsky "AI%20announcement"        /tmp/bluesky/ai_announcements.json
           sleep 1
