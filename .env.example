# ai-research-arm — example environment configuration
#
# Copy to `.env` (gitignored) for local runs, or set these as GitHub Actions
# secrets / repository variables for the automated pipeline. NOTHING here is
# required just to build and preview the dashboard locally — see the
# "Quickstart" section of README.md for the no-accounts path.
#
# Sensitivity legend:
#   [secret]   never commit a real value; store in GitHub Actions secrets
#   [config]   non-secret; safe to commit a value, here for discoverability

# ─── Core LLM backend ────────────────────────────────────────────────
# Required for every Claude-powered workflow (digest, research, timeline…).
CLAUDE_CODE_OAUTH_TOKEN=          # [secret] Claude Code OAuth token

# Required only for generative-research backend=codex.
OPENAI_API_KEY=                   # [secret] OpenAI API key for openai/codex-action

# Alternative / comparison backends. Required only for the DeepSeek-V4-Flash /
# GLM generative-research paths and the non-Claude Twitter comparison lanes.
FIREWORKS_API_KEY=               # [secret] Fireworks (DeepSeek V4 Flash + GLM + Kimi)

# ─── Twitter / X ingestion (bird CLI) ───────────────────────────────
# Bare X/Twitter session cookies. The lanes degrade gracefully to empty data
# when absent, so they are optional for a fork; required to actually pull
# tweets. These EXPIRE frequently and must be refreshed by hand.
BIRD_AUTH_TOKEN=                 # [secret] X auth_token cookie
BIRD_CT0=                        # [secret] X ct0 cookie

# ─── Optional web-search MCP enrichment ─────────────────────────────
EXA_API_KEY=                     # [secret] Exa neural search (optional)
PERPLEXITY_API_KEY=              # [secret] Perplexity search (optional)

# ─── Audio (digest / article TTS) ───────────────────────────────────
GEMINI_API_KEY=                  # [secret] Gemini Flash TTS (optional; audio skipped if unset)

# ─── Telemetry + alerts (all optional; no-op when unset) ────────────
HOOKER_URL=https://hooker.guzus.xyz   # [config] telemetry endpoint base
HOOKER_TOKEN=                    # [secret] telemetry auth (steps no-op without it)
TELEGRAM_BOT_TOKEN=              # [secret] headline-alert delivery bot
TELEGRAM_CHAT_ID=                # [secret] headline-alert destination chat

# ─── Self-hostable service endpoints (non-secret; override to point at
#     your own infra instead of the maintainer's example deployment) ──
# SEC EDGAR requires a contact in the User-Agent; defaults to a project
# noreply. Set this to your own email if you want SEC to be able to reach you.
EDGAR_CONTACT_EMAIL=ai-research-arm@users.noreply.github.com   # [config]
# Where the daily digest/article MP3s are hosted (producer + consumer).
AUDIO_BASE_URL=https://s3.guzus.xyz/obj-ai-research-arm        # [config] (workflows)
VITE_AUDIO_BASE_URL=https://s3.guzus.xyz/obj-ai-research-arm   # [config] (dashboard build)
# Public origin used for canonical/OG/sitemap/RSS URLs in the built dashboard.
POSTBUILD_SITE_ORIGIN=https://ara.guzus.xyz                    # [config]
# Manifest URL the deploy-health watchdog polls.
DEPLOY_HEALTH_URL=https://ara.guzus.xyz/research/manifest.json # [config]

# ─── Legacy (kept for back-compat; prod deploys via Railway git push) ─
VERCEL_DEPLOY_HOOK=              # [secret] legacy Vercel nudge; harmless no-op when unset
